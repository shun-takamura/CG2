<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!--
    EngineCore.lib と Game.exe(CG2_0_1) が共有するコンパイル設定。
    設定の二重化・乖離を防ぐため両 vcxproj がこれを import する。
    インクルードパスは $(SolutionDir) 基準（= Project\）なので vcxproj の置き場所に依存しない。
    静的lib + exe を同じ RuntimeLibrary で揃えるためにも、ここで一元管理する。
  -->
  <ItemDefinitionGroup>
    <ClCompile>
      <WarningLevel>Level3</WarningLevel>
      <SDLCheck>true</SDLCheck>
      <ConformanceMode>true</ConformanceMode>
      <LanguageStandard>stdcpp20</LanguageStandard>
      <AdditionalOptions>/utf-8 %(AdditionalOptions)</AdditionalOptions>
      <MultiProcessorCompilation>true</MultiProcessorCompilation>
      <PrecompiledHeader>NotUsing</PrecompiledHeader>
      <PreprocessorDefinitions>USE_IMGUI;_WINDOWS;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <AdditionalIncludeDirectories>$(SolutionDir)DirectXGame\GameEngine\Profiling;$(SolutionDir)DirectXGame\GameEngine\Graphics\Effect;$(SolutionDir)DirectXGame\GameEngine\Graphics\Primitive;$(SolutionDir)DirectXGame\GameEngine\Graphics\Particle;$(SolutionDir)DirectXGame\GameEngine\Graphics\OffscreenRendering\FilterEffect;$(SolutionDir)DirectXGame\GameEngine\Graphics\Skybox;$(SolutionDir)DirectXGame\GameEngine\Graphics\OffscreenRendering;$(SolutionDir)DirectXGame\GameEngine\Graphics\Object3D;$(SolutionDir)DirectXGame\GameEngine\Sound;$(SolutionDir)DirectXGame\ImGUIManager;$(SolutionDir)DirectXGame\Game\Scene\Transition;$(SolutionDir)DirectXGame\GameEngine;$(SolutionDir)DirectXGame\Game\Actors;$(SolutionDir)DirectXGame\Game\Spline;$(SolutionDir)DirectXGame\Game\UI;$(SolutionDir)DirectXGame\Game\Scene;$(SolutionDir)DirectXGame\Game;$(SolutionDir)DirectXGame\Debug;$(SolutionDir)DirectXGame\GameEngine\Graphics\Sprite;$(SolutionDir)DirectXGame\Game\Entity;$(SolutionDir)DirectXGame\Game\Map;$(SolutionDir)DirectXGame\GameEngine\Entity;$(SolutionDir)DirectXGame\GameEngine\Core;$(SolutionDir)DirectXGame\GameEngine\Audio;$(SolutionDir)DirectXGame\GameEngine\Entity\Components;$(SolutionDir)DirectXGame\GameEngine\Graphics;$(SolutionDir)DirectXGame\GameEngine\Graphics\Light;$(SolutionDir)DirectXGame\GameEngine\Graphics\Shadow;$(SolutionDir)DirectXGame\GameEngine\Graphics\Camera;$(SolutionDir)DirectXGame\GameEngine\Utility;$(SolutionDir)DirectXGame\GameEngine\Math;$(SolutionDir)externals\quirc;$(SolutionDir)externals\assimp\include;$(SolutionDir)DirectXGame\GameEngine\Scene;$(SolutionDir)externals\DirectXTex;$(SolutionDir)externals\ImGui_Docking;$(SolutionDir)externals\ImGui_Docking\backends;$(SolutionDir)Resources\Shaders;$(SolutionDir)Resources\Shaders\hlsli;$(SolutionDir)DirectXGame\GameEngine\Core\Input;$(SolutionDir)DirectXGame\GameEngine\Graphics\Text;$(SolutionDir)DirectXGame\GameEngine\External;$(SolutionDir)DirectXGame\Game\Score;$(SolutionDir)externals\std_truetype;%(AdditionalIncludeDirectories);$(SolutionDir)externals\DirectStorage\include</AdditionalIncludeDirectories>
    </ClCompile>
  </ItemDefinitionGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)'=='Debug'">
    <ClCompile>
      <PreprocessorDefinitions>_DEBUG;USE_PEPPER;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <RuntimeLibrary>MultiThreadedDebug</RuntimeLibrary>
    </ClCompile>
  </ItemDefinitionGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)'=='Release'">
    <ClCompile>
      <PreprocessorDefinitions>NDEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <RuntimeLibrary>MultiThreaded</RuntimeLibrary>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <TreatWarningAsError>true</TreatWarningAsError>
    </ClCompile>
  </ItemDefinitionGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)'=='Development'">
    <ClCompile>
      <PreprocessorDefinitions>NDEBUG;USE_PEPPER;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <RuntimeLibrary>MultiThreaded</RuntimeLibrary>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <TreatWarningAsError>true</TreatWarningAsError>
      <Optimization>Disabled</Optimization>
      <WholeProgramOptimization>false</WholeProgramOptimization>
    </ClCompile>
  </ItemDefinitionGroup>
</Project>
